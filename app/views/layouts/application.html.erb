<!DOCTYPE html>
<html lang="ja">
  <head>
    <title><%= content_for(:title) || "Tsundoku" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="Tsundokuは読書が続かない人、積読しがちな人向けの読書管理アプリです。読んできた本の一覧表示と読書ログを公開することにより、外部に読書習慣をアピールできます！">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-white font-sans text-ink antialiased">
    <%= render "shared/header" if current_user %>
    <% if flash.any? %>
      <div class="fixed inset-x-0 top-4 z-50 flex flex-col items-center gap-2">
        <% flash.each do |type, message| %>
          <p class="rounded-md bg-ink px-4 py-2 text-sm text-white shadow-lg"><%= message %></p>
        <% end %>
      </div>
    <% end %>
    <main class="min-h-screen p-4">
      <%= yield %>
    </main>
    <%= render "shared/footer" %>
  </body>
</html>
