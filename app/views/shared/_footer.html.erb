<footer class="mx-auto max-w-[960px] border-t border-gray-200 px-4">
  <div class="flex flex-col items-center gap-4 py-6 sm:flex-row sm:justify-between">
    <div class="flex items-center gap-2">
      <%= image_tag "Tsundoku.png", alt: "ロゴ", size: "28x28" %>
      <span class="text-xl font-bold">Tsundoku</span>
    </div>

